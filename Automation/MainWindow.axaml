<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Automation.MainWindow"
        Title="Система автоматизации кадрового учета"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#2C3E50" Padding="10">
            <StackPanel>
                <TextBlock Text="Кадровый учет" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          Foreground="White"
                          Margin="0,0,0,20"
                          HorizontalAlignment="Center"/>
                
                <Button Name="BtnEmployees" 
                        Content="📋 Сотрудники" 
                        Click="ShowEmployees"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnDepartments" 
                        Content="🏢 Отделы" 
                        Click="ShowDepartments"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnPositions" 
                        Content="💼 Должности" 
                        Click="ShowPositions"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnVacations" 
                        Content="🏖️ Отпуска" 
                        Click="ShowVacations"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnSalaries" 
                        Content="💰 Зарплаты" 
                        Click="ShowSalaries"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnSchedule" 
                        Content="📅 Табель" 
                        Click="ShowSchedule"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
                
                <Button Name="BtnReports" 
                        Content="📊 Отчеты" 
                        Click="ShowReports"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Margin="0,5"
                        Padding="10"/>
            </StackPanel>
        </Border>
        
        <!-- Основная область контента -->
        <Border Grid.Column="1" Background="White" Padding="20">
            <ContentControl Name="ContentArea">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Добро пожаловать!" 
                              FontSize="24" 
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,10"/>
                    <TextBlock Text="Выберите раздел в меню слева" 
                              FontSize="16" 
                              Foreground="Gray"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </ContentControl>
        </Border>
    </Grid>
</Window>
