<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Automation.Views.PositionFormWindow"
        Title="Должность"
        Width="500" Height="350"
        WindowStartupLocation="CenterOwner">
    
    <StackPanel Margin="20">
        <TextBlock Text="Название *" Margin="0,5,0,2"/>
        <TextBox Name="TxtName" Watermark="Название должности"/>
        
        <TextBlock Text="Базовый оклад *" Margin="0,10,0,2"/>
        <NumericUpDown Name="NumSalary" 
                      Minimum="0"
                      Maximum="1000000"
                      Increment="1000"
                      FormatString="N2"/>
        
        <TextBlock Text="Требования" Margin="0,10,0,2"/>
        <TextBox Name="TxtRequirements" 
                 Watermark="Требования к должности"
                 Height="100"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"/>
        
        <StackPanel Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">
            <Button Name="BtnSave" 
                   Content="💾 Сохранить"
                   Click="OnSave"
                   Width="120"
                   Margin="0,0,10,0"/>
            <Button Name="BtnCancel" 
                   Content="❌ Отмена"
                   Click="OnCancel"
                   Width="120"/>
        </StackPanel>
    </StackPanel>
</Window>
