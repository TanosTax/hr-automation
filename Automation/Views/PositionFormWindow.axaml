<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Automation.Views.PositionFormWindow"
        Title="Должность"
        Width="550" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    
    <StackPanel Margin="30">
        <!-- Заголовок -->
        <Border Classes="Card" Margin="0,0,0,25">
            <TextBlock Text="💼 Должность" 
                      FontSize="24" 
                      FontWeight="Bold"
                      Foreground="White"/>
        </Border>
        
        <!-- Форма -->
        <Border Classes="Card" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Название *" Margin="0,5,0,5" Foreground="#E0E0E0"/>
                <TextBox Name="TxtName" Watermark="Название должности"/>
                
                <TextBlock Text="Базовый оклад *" Margin="0,15,0,5" Foreground="#E0E0E0"/>
                <NumericUpDown Name="NumSalary" 
                              Minimum="0"
                              Maximum="1000000"
                              Increment="1000"
                              FormatString="N0"
                              HorizontalAlignment="Stretch"/>
                
                <TextBlock Text="Требования" Margin="0,15,0,5" Foreground="#E0E0E0"/>
                <TextBox Name="TxtRequirements" 
                         Watermark="Требования к должности"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- Кнопки -->
        <Grid ColumnDefinitions="*,*">
            <Button Name="BtnSave" 
                   Grid.Column="0"
                   Content="💾 Сохранить"
                   Classes="Primary"
                   Click="OnSave"
                   HorizontalAlignment="Stretch"
                   Padding="0,12"
                   Margin="0,0,8,0"/>
            <Button Name="BtnCancel" 
                   Grid.Column="1"
                   Content="❌ Отмена"
                   Classes="Secondary"
                   Click="OnCancel"
                   HorizontalAlignment="Stretch"
                   Padding="0,12"
                   Margin="8,0,0,0"/>
        </Grid>
    </StackPanel>
</Window>
