<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.WorkScheduleView">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" 
                   Text="Табель учета рабочего времени" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1" ColumnDefinitions="Auto,200,Auto,*" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker Name="DatePicker" Grid.Column="1" Margin="0,0,20,0"/>
            <Button Name="BtnLoad" Grid.Column="2" Content="Загрузить" Click="OnLoad"/>
        </Grid>
        
        <DataGrid Grid.Row="2" 
                  Name="ScheduleGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="200"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Employee.Department.Name}" Width="150"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100"/>
                <DataGridTextColumn Header="Приход" Binding="{Binding CheckIn}" Width="80"/>
                <DataGridTextColumn Header="Уход" Binding="{Binding CheckOut}" Width="80"/>
                <DataGridTextColumn Header="Часов" Binding="{Binding WorkedHours}" Width="80"/>
                <DataGridCheckBoxColumn Header="Отсутствие" Binding="{Binding IsAbsent}" Width="100"/>
                <DataGridTextColumn Header="Причина" Binding="{Binding AbsenceReason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Name="BtnAdd" 
                    Content="➕ Добавить запись"
                    Click="OnAdd"/>
        </StackPanel>
    </Grid>
</UserControl>
