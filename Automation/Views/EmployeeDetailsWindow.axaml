<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Automation.Views.EmployeeDetailsWindow"
        Title="Карточка сотрудника"
        Width="800" Height="700"
        WindowStartupLocation="CenterOwner">
    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1E1E1E" Offset="0"/>
            <GradientStop Color="#1A1A1A" Offset="0.5"/>
            <GradientStop Color="#0F0F0F" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    
    <ScrollViewer>
        <StackPanel Margin="35">
            <!-- Заголовок с именем -->
            <Border Classes="Card" Margin="0,0,0,28" BoxShadow="0 8 28 0 #00000070, 0 4 12 0 #0E639C50" Padding="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#0E639C" Offset="0"/>
                        <GradientStop Color="#1177BB" Offset="0.5"/>
                        <GradientStop Color="#1A8FDD" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Name="TxtFullName" 
                              FontSize="32" 
                              FontWeight="Black"
                              Foreground="White"
                              HorizontalAlignment="Center"/>
                    <TextBlock Name="TxtPosition" 
                              FontSize="17" 
                              FontWeight="Medium"
                              Foreground="#D0EFFF"
                              HorizontalAlignment="Center"
                              Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            
            <!-- Основная информация -->
            <Border Classes="Card" Margin="0,0,0,22">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="📧 Email:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,12"/>
                    <TextBlock Name="TxtEmail" Grid.Row="0" Grid.Column="1" Foreground="White" FontWeight="Medium" Margin="12,0,0,12"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="📱 Телефон:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,12"/>
                    <TextBlock Name="TxtPhone" Grid.Row="1" Grid.Column="1" Foreground="White" FontWeight="Medium" Margin="12,0,0,12"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="🏢 Отдел:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,12"/>
                    <TextBlock Name="TxtDepartment" Grid.Row="2" Grid.Column="1" Foreground="White" FontWeight="Medium" Margin="12,0,0,12"/>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="🎂 Дата рождения:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,12"/>
                    <TextBlock Name="TxtBirthDate" Grid.Row="3" Grid.Column="1" Foreground="White" FontWeight="Medium" Margin="12,0,0,12"/>
                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="📅 Дата приема:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,12"/>
                    <TextBlock Name="TxtHireDate" Grid.Row="4" Grid.Column="1" Foreground="White" FontWeight="Medium" Margin="12,0,0,12"/>
                    
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="📍 Адрес:" Foreground="#A0A0A0" FontWeight="Medium" Margin="0,0,12,0"/>
                    <TextBlock Name="TxtAddress" Grid.Row="5" Grid.Column="1" Foreground="White" FontWeight="Medium" TextWrapping="Wrap" Margin="12,0,0,0"/>
                </Grid>
            </Border>
            
            <!-- Контракты -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="📄 Контракты" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    <DataGrid Name="ContractsGrid"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             MaxHeight="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding ContractNumber}" Width="Auto"/>
                            <DataGridTextColumn Header="Дата подписания" Binding="{Binding SignDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                            <DataGridTextColumn Header="Окончание" Binding="{Binding EndDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Отпуска -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="🏖️ Отпуска" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    <DataGrid Name="VacationsGrid"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             MaxHeight="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                            <DataGridTextColumn Header="Конец" Binding="{Binding EndDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                            <DataGridTextColumn Header="Дней" Binding="{Binding DaysCount}" Width="Auto"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Документы -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="📋 Документы" 
                              FontSize="20" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    <DataGrid Name="DocumentsGrid"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             MaxHeight="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="Auto"/>
                            <DataGridTextColumn Header="Дата выдачи" Binding="{Binding IssueDate, StringFormat='{}{0:dd.MM.yyyy}'}" Width="Auto"/>
                            <DataGridTextColumn Header="Кем выдан" Binding="{Binding IssuedBy}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- Кнопка закрыть -->
            <Button Name="BtnClose" 
                   Content="✖️ Закрыть"
                   Classes="Secondary"
                   Click="OnClose"
                   HorizontalAlignment="Stretch"
                   Padding="0,16"/>
        </StackPanel>
    </ScrollViewer>
</Window>
