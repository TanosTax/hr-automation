<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.EmployeeListView">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Список сотрудников" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        
        <!-- Панель поиска и фильтров -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
            <TextBox Name="SearchBox" 
                     Grid.Column="0"
                     Watermark="Поиск по ФИО или email..."
                     Margin="0,0,10,0"/>
            <Button Name="BtnSearch" 
                    Grid.Column="1"
                    Content="🔍 Найти"
                    Click="OnSearch"
                    Margin="0,0,10,0"/>
            <Button Name="BtnAdd" 
                    Grid.Column="2"
                    Content="➕ Добавить"
                    Click="OnAdd"/>
        </Grid>
        
        <!-- Таблица сотрудников -->
        <DataGrid Grid.Row="2" 
                  Name="EmployeesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="150"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Department.Name}" Width="150"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position.Name}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- Кнопки действий -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Name="BtnView" 
                    Content="👁️ Просмотр"
                    Click="OnView"
                    Margin="0,0,10,0"/>
            <Button Name="BtnEdit" 
                    Content="✏️ Редактировать"
                    Click="OnEdit"
                    Margin="0,0,10,0"/>
            <Button Name="BtnDelete" 
                    Content="🗑️ Уволить"
                    Click="OnDelete"/>
        </StackPanel>
    </Grid>
</UserControl>
