<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.EmployeeListView">
    
    <Grid RowDefinitions="Auto,Auto,*" Margin="25">
        <!-- Заголовок -->
        <Border Grid.Row="0" Margin="0,0,0,25" CornerRadius="16" BoxShadow="0 8 28 0 #00000060, 0 4 12 0 #0E639C40" Padding="30,26">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0E639C" Offset="0"/>
                    <GradientStop Color="#1177BB" Offset="0.5"/>
                    <GradientStop Color="#1A8FDD" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="👥 Сотрудники" 
                               FontSize="32" 
                               FontWeight="Black"
                               Foreground="White"/>
                    <TextBlock Text="Управление персоналом компании" 
                               FontSize="15" 
                               FontWeight="Medium"
                               Foreground="#D0EFFF"
                               Margin="0,8,0,0"/>
                </StackPanel>
                <Button Name="BtnAdd" 
                        Grid.Column="1"
                        Content="➕ Добавить сотрудника"
                        Classes="Success"
                        Click="OnAdd"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Панель поиска и фильтров -->
        <Border Grid.Row="1" Classes="Card" Margin="0,0,0,25">
            <StackPanel>
                <!-- Поиск -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,15">
                    <TextBox Name="SearchBox" 
                             Grid.Column="0"
                             Watermark="🔍 Поиск по ФИО или email..."
                             TextChanged="OnSearchTextChanged"
                             Margin="0,0,15,0"/>
                    <Button Name="BtnView" 
                            Grid.Column="1"
                            Content="👁️ Просмотр"
                            Classes="Secondary"
                            Click="OnView"
                            Margin="0,0,12,0"/>
                    <Button Name="BtnEdit" 
                            Grid.Column="2"
                            Content="✏️ Редактировать"
                            Classes="Secondary"
                            Click="OnEdit"
                            Margin="0,0,12,0"/>
                    <Button Name="BtnDelete" 
                            Grid.Column="3"
                            Content="🗑️ Уволить"
                            Classes="Danger"
                            Click="OnDelete"/>
                </Grid>
                
                <!-- Фильтры и сортировка -->
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" 
                              Text="Отдел:" 
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <ComboBox Name="DepartmentFilter" 
                             Grid.Column="1"
                             SelectionChanged="OnFilterChanged"
                             Margin="0,0,20,0"/>
                    
                    <TextBlock Grid.Column="2" 
                              Text="Должность:" 
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <ComboBox Name="PositionFilter" 
                             Grid.Column="3"
                             SelectionChanged="OnFilterChanged"
                             Margin="0,0,20,0"/>
                    
                    <TextBlock Grid.Column="4" 
                              Text="Сортировка:" 
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"/>
                    <ComboBox Name="SortComboBox" 
                             Grid.Column="5"
                             SelectionChanged="OnSortChanged"
                             SelectedIndex="0">
                        <ComboBoxItem Content="По фамилии (А-Я)"/>
                        <ComboBoxItem Content="По фамилии (Я-А)"/>
                        <ComboBoxItem Content="По дате приема (новые)"/>
                        <ComboBoxItem Content="По дате приема (старые)"/>
                        <ComboBoxItem Content="По возрасту (младшие)"/>
                        <ComboBoxItem Content="По возрасту (старшие)"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- Таблица сотрудников -->
        <DataGrid Grid.Row="2" 
                  Name="EmployeesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="Auto"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="Auto"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="Auto"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Department.Name}" Width="Auto"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position.Name}" Width="Auto"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="Auto"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
