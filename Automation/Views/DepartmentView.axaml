<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.DepartmentView">
    
    <Grid RowDefinitions="Auto,*" Margin="25">
        <!-- Заголовок -->
        <Border Grid.Row="0" Margin="0,0,0,25" CornerRadius="16" BoxShadow="0 8 28 0 #00000060, 0 4 12 0 #107C1040" Padding="30,26">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#107C10" Offset="0"/>
                    <GradientStop Color="#0F8B0F" Offset="0.5"/>
                    <GradientStop Color="#10A010" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏢 Отделы" 
                               FontSize="32" 
                               FontWeight="Black"
                               Foreground="White"/>
                    <TextBlock Text="Структура организации" 
                               FontSize="15" 
                               FontWeight="Medium"
                               Foreground="#E0FFE0"
                               Margin="0,8,0,0"/>
                </StackPanel>
                <Button Name="BtnAdd" 
                        Grid.Column="1"
                        Content="➕ Добавить"
                        Classes="Success"
                        Click="OnAdd"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>
                <Button Name="BtnEdit" 
                        Grid.Column="2"
                        Content="✏️ Редактировать"
                        Classes="Secondary"
                        Click="OnEdit"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"/>
                <Button Name="BtnDelete" 
                        Grid.Column="3"
                        Content="🗑️ Удалить"
                        Classes="Danger"
                        Click="OnDelete"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Таблица -->
        <DataGrid Grid.Row="1" 
                  Name="DepartmentsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="Auto"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Сотрудников" Binding="{Binding Employees.Count}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
