<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.DepartmentView">
    
    <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" 
                   Text="Справочник отделов" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        
        <DataGrid Grid.Row="1" 
                  Name="DepartmentsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Сотрудников" Binding="{Binding Employees.Count}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Name="BtnAdd" 
                    Content="➕ Добавить"
                    Click="OnAdd"
                    Margin="0,0,10,0"/>
            <Button Name="BtnEdit" 
                    Content="✏️ Редактировать"
                    Click="OnEdit"
                    Margin="0,0,10,0"/>
            <Button Name="BtnDelete" 
                    Content="🗑️ Удалить"
                    Click="OnDelete"/>
        </StackPanel>
    </Grid>
</UserControl>
