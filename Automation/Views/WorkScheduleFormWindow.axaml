<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Automation.Views.WorkScheduleFormWindow"
        Title="Запись в табель"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner">
    
    <StackPanel Margin="20">
        <TextBlock Text="Сотрудник *" Margin="0,5,0,2"/>
        <ComboBox Name="CmbEmployee" 
                 DisplayMemberBinding="{Binding FullName}"
                 HorizontalAlignment="Stretch"/>
        
        <TextBlock Text="Дата *" Margin="0,10,0,2"/>
        <DatePicker Name="DatePicker"/>
        
        <TextBlock Text="Время прихода" Margin="0,10,0,2"/>
        <TimePicker Name="TimeCheckIn"/>
        
        <TextBlock Text="Время ухода" Margin="0,10,0,2"/>
        <TimePicker Name="TimeCheckOut"/>
        
        <CheckBox Name="ChkAbsent" Content="Отсутствие" Margin="0,10,0,2"/>
        
        <TextBlock Text="Причина отсутствия" Margin="0,10,0,2"/>
        <TextBox Name="TxtReason" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
        
        <StackPanel Orientation="Horizontal" 
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">
            <Button Name="BtnSave" 
                   Content="💾 Сохранить"
                   Click="OnSave"
                   Width="120"
                   Margin="0,0,10,0"/>
            <Button Name="BtnCancel" 
                   Content="❌ Отмена"
                   Click="OnCancel"
                   Width="120"/>
        </StackPanel>
    </StackPanel>
</Window>
