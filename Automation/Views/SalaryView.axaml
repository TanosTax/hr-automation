<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.SalaryView">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0" 
                   Text="Начисление зарплаты" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1" ColumnDefinitions="Auto,150,Auto,150,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Column="0" Text="Год:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <NumericUpDown Name="NumYear" Grid.Column="1" Minimum="2020" Maximum="2030" Margin="0,0,20,0"/>
            
            <TextBlock Grid.Column="2" Text="Месяц:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <NumericUpDown Name="NumMonth" Grid.Column="3" Minimum="1" Maximum="12" Margin="0,0,20,0"/>
            
            <Button Name="BtnFilter" Grid.Column="4" Content="Показать" Click="OnFilter"/>
        </Grid>
        
        <DataGrid Grid.Row="2" 
                  Name="SalariesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="200"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Employee.Department.Name}" Width="150"/>
                <DataGridTextColumn Header="Оклад" Binding="{Binding BaseSalary, StringFormat='{}{0:N2}'}" Width="100"/>
                <DataGridTextColumn Header="Премия" Binding="{Binding Bonus, StringFormat='{}{0:N2}'}" Width="100"/>
                <DataGridTextColumn Header="Удержания" Binding="{Binding Deductions, StringFormat='{}{0:N2}'}" Width="100"/>
                <DataGridTextColumn Header="Итого" Binding="{Binding Total, StringFormat='{}{0:N2}'}" Width="120"/>
                <DataGridCheckBoxColumn Header="Выплачено" Binding="{Binding IsPaid}" Width="100"/>
                <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Name="BtnAdd" 
                    Content="➕ Начислить"
                    Click="OnAdd"
                    Margin="0,0,10,0"/>
            <Button Name="BtnMarkPaid" 
                    Content="✅ Отметить выплату"
                    Click="OnMarkPaid"/>
        </StackPanel>
    </Grid>
</UserControl>
