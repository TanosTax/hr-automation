<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Automation.Views.SalaryView">
    
    <Grid RowDefinitions="Auto,Auto,*" Margin="25">
        <!-- Заголовок -->
        <Border Grid.Row="0" Margin="0,0,0,25" CornerRadius="16" BoxShadow="0 8 28 0 #00000060, 0 4 12 0 #D9770640" Padding="30,26">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#D97706" Offset="0"/>
                    <GradientStop Color="#F59E0B" Offset="0.5"/>
                    <GradientStop Color="#FBBF24" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💰 Зарплаты" 
                               FontSize="32" 
                               FontWeight="Black"
                               Foreground="White"/>
                    <TextBlock Text="Начисление и выплата заработной платы" 
                               FontSize="15" 
                               FontWeight="Medium"
                               Foreground="#FEF3C7"
                               Margin="0,8,0,0"/>
                </StackPanel>
                <Button Name="BtnAdd" 
                        Grid.Column="1"
                        Content="➕ Начислить"
                        Classes="Success"
                        Click="OnAdd"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Фильтры -->
        <Border Grid.Row="1" Classes="Card" Margin="0,0,0,25">
            <Grid ColumnDefinitions="Auto,160,Auto,160,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Год:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="White" FontWeight="Medium"/>
                <NumericUpDown Name="NumYear" Grid.Column="1" Minimum="2020" Maximum="2030" Margin="0,0,20,0"/>
                
                <TextBlock Grid.Column="2" Text="Месяц:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="White" FontWeight="Medium"/>
                <NumericUpDown Name="NumMonth" Grid.Column="3" Minimum="1" Maximum="12" Margin="0,0,20,0"/>
                
                <Button Name="BtnFilter" 
                        Grid.Column="4" 
                        Content="🔍 Показать" 
                        Classes="Secondary"
                        Click="OnFilter"
                        Margin="0,0,12,0"/>
                <Button Name="BtnMarkPaid" 
                        Grid.Column="5"
                        Content="✅ Отметить выплату"
                        Classes="Primary"
                        Click="OnMarkPaid"/>
            </Grid>
        </Border>
        
        <!-- Таблица -->
        <DataGrid Grid.Row="2" 
                  Name="SalariesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee.FullName}" Width="Auto"/>
                <DataGridTextColumn Header="Отдел" Binding="{Binding Employee.Department.Name}" Width="Auto"/>
                <DataGridTextColumn Header="Период" Binding="{Binding Month}" Width="Auto"/>
                <DataGridTextColumn Header="Оклад" Binding="{Binding BaseSalary, StringFormat='{}{0:N0} ₽'}" Width="Auto"/>
                <DataGridTextColumn Header="Премия" Binding="{Binding Bonus, StringFormat='{}{0:N0} ₽'}" Width="Auto"/>
                <DataGridTextColumn Header="Удержания" Binding="{Binding Deductions, StringFormat='{}{0:N0} ₽'}" Width="Auto"/>
                <DataGridTextColumn Header="Итого" Binding="{Binding Total, StringFormat='{}{0:N0} ₽'}" Width="Auto"/>
                <DataGridCheckBoxColumn Header="Выплачено" Binding="{Binding IsPaid}" Width="Auto"/>
                <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
