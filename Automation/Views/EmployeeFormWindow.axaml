<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Automation.Views.EmployeeFormWindow"
        Title="Сотрудник"
        Width="650" Height="750"
        WindowStartupLocation="CenterOwner">
    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1E1E1E" Offset="0"/>
            <GradientStop Color="#1A1A1A" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    
    <ScrollViewer>
        <StackPanel Margin="35">
            <!-- Заголовок -->
            <Border Classes="Card" Margin="0,0,0,28" BoxShadow="0 6 20 0 #00000050">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#0E639C" Offset="0"/>
                        <GradientStop Color="#1177BB" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="👤 Информация о сотруднике" 
                          FontSize="26" 
                          FontWeight="Black"
                          Foreground="White"
                          Padding="6"/>
            </Border>
            
            <!-- Личные данные -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Личные данные" 
                              FontSize="17" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    
                    <TextBlock Text="Фамилия *" Margin="0,5,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtLastName" Watermark="Иванов"/>
                    
                    <TextBlock Text="Имя *" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtFirstName" Watermark="Иван"/>
                    
                    <TextBlock Text="Отчество" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtMiddleName" Watermark="Иванович"/>
                    
                    <TextBlock Text="Дата рождения *" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <DatePicker Name="DateBirth"/>
                </StackPanel>
            </Border>
            
            <!-- Паспортные данные -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Паспортные данные" 
                              FontSize="17" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Серия" Margin="0,5,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                            <TextBox Name="TxtPassportSeries" Watermark="1234"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Номер" Margin="0,5,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                            <TextBox Name="TxtPassportNumber" Watermark="567890"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Контакты -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Контактная информация" 
                              FontSize="17" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    
                    <TextBlock Text="Адрес" Margin="0,5,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtAddress" Watermark="г. Москва, ул. Ленина, д. 1"/>
                    
                    <TextBlock Text="Телефон" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtPhone" Watermark="+7 (999) 123-45-67"/>
                    
                    <TextBlock Text="Email" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <TextBox Name="TxtEmail" Watermark="ivanov@example.com"/>
                </StackPanel>
            </Border>
            
            <!-- Рабочая информация -->
            <Border Classes="Card" Margin="0,0,0,22">
                <StackPanel>
                    <TextBlock Text="Рабочая информация" 
                              FontSize="17" 
                              FontWeight="Bold"
                              Foreground="#1A8FDD"
                              Margin="0,0,0,18"/>
                    
                    <TextBlock Text="Отдел *" Margin="0,5,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <ComboBox Name="CmbDepartment" 
                             DisplayMemberBinding="{Binding Name}"
                             HorizontalAlignment="Stretch"/>
                    
                    <TextBlock Text="Должность *" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <ComboBox Name="CmbPosition" 
                             DisplayMemberBinding="{Binding Name}"
                             HorizontalAlignment="Stretch"/>
                    
                    <TextBlock Text="Дата приема *" Margin="0,18,0,7" Foreground="#E0E0E0" FontWeight="Medium"/>
                    <DatePicker Name="DateHire"/>
                </StackPanel>
            </Border>
            
            <!-- Кнопки -->
            <Grid ColumnDefinitions="*,*">
                <Button Name="BtnSave" 
                       Grid.Column="0"
                       Content="💾 Сохранить"
                       Classes="Primary"
                       Click="OnSave"
                       HorizontalAlignment="Stretch"
                       Padding="0,14"
                       Margin="0,0,10,0"/>
                <Button Name="BtnCancel" 
                       Grid.Column="1"
                       Content="❌ Отмена"
                       Classes="Secondary"
                       Click="OnCancel"
                       HorizontalAlignment="Stretch"
                       Padding="0,14"
                       Margin="10,0,0,0"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
